# App URL (update for production)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_API_URL=https://your-app.vercel.app/api

# Database (Neon PostgreSQL recommended for Vercel)
# Get your connection string from Neon dashboard
DATABASE_URL=postgresql://username:password@host.neon.tech/dbname?sslmode=require

# Better Auth (generate a secure secret: openssl rand -base64 32)
BETTER_AUTH_SECRET=your-secret-key-min-32-chars-long-here
BETTER_AUTH_URL=https://your-app.vercel.app